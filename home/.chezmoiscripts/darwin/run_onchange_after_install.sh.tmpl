{{- /* Taps to install */ -}}
{{- $taps := .packages.homebrew.taps -}}

{{- /* Packages to install */ -}}
{{- $formula := (concat .packages.common.tools .packages.homebrew.formula) | sortAlpha | uniq -}}
{{- $casks := (concat .packages.common.apps .packages.homebrew.casks) | sortAlpha | uniq -}}
{{- $mas :=  .packages.mas -}}


#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# Install applications and tools
# ---------------------------------------------------------------------------

{{/* Include external functions */}}
{{ template "install-rust.tmpl" . }}

#################### Main Program ####################

# Stop script on error
set -eo pipefail

# Setup environment
eval "$($(brew --prefix)/bin/brew shellenv)"

# Install packages
brew bundle --file=/dev/stdin <<EOF
{{ range $taps -}} tap {{ . | quote }} {{ end -}}
{{ range $formula -}} brew {{ . | quote }} {{ end -}}
{{ range $casks -}} cask {{ . | quote }} {{ end -}}
EOF

# Install Mac App Store
{{- range $name, $id := $mas }}
mas "{{ $name }}", id: {{ $id }}
{{- end }}

# Install Rust
install_rust
