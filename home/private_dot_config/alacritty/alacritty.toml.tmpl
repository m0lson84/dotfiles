[general]
live_config_reload = true
working_directory  = "None"
import = [
  '~/.config/alacritty/keybinds.toml',
  '~/.config/alacritty/theme.toml'
]

[terminal]
shell = { program = "fish" }

[env]
TERM = "xterm-256color"

[window]
title                     = 'Terminal'
class                     = { general = "Alacritty", instance = "Alacritty" }
dimensions                = { columns = 120, lines = 40 }
decorations_theme_variant = "Dark"
option_as_alt             = "Both"
dynamic_padding           = true
dynamic_title             = false

[scrolling]
history    = 10000
multiplier = 3

[font]
size = {{ $size }}
{{- range $styles }}

[font.{{ index . 0 }}]
family = "{{ $family }}"
style  = "{{ index . 1 }}"
{{- end }}

[cursor]
style = { shape = "Block", blinking = "Never" }

[selection]
semantic_escape_chars = ",│`|:\"' ()[]{}<>\t"
save_to_clipboard     = true
