{{- /* Font settings */ -}}
{{- $family := "JetBrains Mono" -}}
{{- $size := 9 -}}
{{- $style := "Regular" -}}
{{- $styles := list
  (list "normal" $style)
  (list "bold" "Bold")
  (list "italic" "Italic")
  (list "bold_italic" "Bold Italic")
-}}

{{- if eq .env.os "darwin" -}}
  {{- $size = 12 -}}
{{- end -}}

