{{- /* Update applications */ -}}
{{- $update := "_arch_update && _tool_update" -}}
{{- if has .env.distro (list "ubuntu") -}} {{- $update = "_apt_update" -}} {{- end -}}


#######################################
# Update all installed packages
#######################################
function upgrayedd --description "Update all installed packages"
   {{ $update }}
end


#######################################
# Update all apt packages
#######################################
function _apt_update --description "Update all installed apt packages"
    echo "Updating apt packages..."
    sudo apt update && sudo apt upgrade -y
    echo "Running cleaning up tasks..."
    sudo apt autoremove -y && sudo apt autoclean
end


#######################################
# Update all Arch Linux packages
#######################################
function _arch_update --description "Update all Arch Linux packages"
    echo "Updating packages..."
    paru -Syu --noconfirm
    paru -c
end


#######################################
# Update developer tools
#######################################
function _tool_update --description "Update developer tools"
    echo "Updating mise-en-place..."
    mise self-update -y && mise up
    echo "Updating neovim..."
    bob update --all
end
