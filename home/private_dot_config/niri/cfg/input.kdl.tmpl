// ────────────── Input Configuration ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Input

input {
    keyboard {
        xkb {
            layout "us"
        }
        numlock
    }

    {{- if ne .chezmoi.hostname "deep-thought" }}
    touchpad {
        natural-scroll
        click-method "clickfinger"
    }
    {{- end }}

    focus-follows-mouse
    workspace-auto-back-and-forth
}
