{
  "$schema": "https://opencode.ai/config.json",
  "logLevel": "DEBUG",
  "enabled_providers": ["amazon-bedrock", "github-copilot", "ollama"],
  "model": "github-copilot/claude-opus-4.7",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "profile": "bedrock",
        "region": "us-east-1"
      }
    },
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:latest": {
          "name": "Gemma 4"
        },
        "qwen3.6:latest": {
          "name": "Qwen 3.6",
          "variants": {
            "high": {},
            "low": {
              "reasoningEffort": "none"
            }
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "lsp": {},
  "permission": {
    "bash": {
      "git *": "ask",
      "*": "allow"
    }
  }
}
