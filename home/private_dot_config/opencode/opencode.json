{
  "$schema": "https://opencode.ai/config.json",
  "logLevel": "DEBUG",
  "enabled_providers": ["amazon-bedrock", "github-copilot"],
  "model": "github-copilot/claude-sonnet-5",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "profile": "bedrock",
        "region": "us-east-1"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "lsp": {},
  "permission": {
    "bash": {
      "git *": "ask",
      "*": "allow"
    }
  }
}
